MONGO_URI=mongodb://127.0.0.1:27017/codeexplainer
PORT=5000
JWT_SECRET=replace-with-strong-secret

# AI mode:
# mock => free/local deterministic insights (default, no external API key required)
# openai_compat => any OpenAI-compatible endpoint (OpenRouter, LocalAI, etc.)
AI_PROVIDER=mock

# Used only when AI_PROVIDER=openai_compat
AI_API_URL=https://openrouter.ai/api/v1/chat/completions
AI_MODEL=meta-llama/llama-3.1-8b-instruct:free
AI_API_KEY=

# Optional headers used by some providers (OpenRouter)
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=Code Explainer
